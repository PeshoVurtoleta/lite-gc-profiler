{
  "name": "@zakkster/lite-gc-profiler",
  "version": "1.5.2",
  "description": "Zero-dependency GC and heap profiler that makes the zero-GC claim falsifiable: three-state verdicts, phases, regions, differential and rep-aware gating, baselines, CLI, and explain mode. precise garbage-collection events in node (perf_hooks), a heap-drop heuristic in Chrome, and long-frame anomaly detection everywhere else.",
  "type": "module",
  "main": "./Gc.js",
  "module": "./Gc.js",
  "types": "./Gc.d.ts",
  "exports": {
    ".": {
      "types": "./Gc.d.ts",
      "node": "./Gc.js",
      "import": "./Gc.js",
      "default": "./Gc.js"
    },
    "./register": {
      "node": "./Register.mjs",
      "default": "./Register.mjs"
    },
    "./test-helpers": {
      "types": "./TestHelpers.d.ts",
      "node": "./TestHelpers.js",
      "import": "./TestHelpers.js",
      "default": "./TestHelpers.js"
    },
    "./index.js": {
      "types": "./index.d.ts",
      "node": "./index.js",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./explain": {
      "types": "./Explain.d.ts",
      "node": "./Explain.js",
      "import": "./Explain.js",
      "default": "./Explain.js"
    }
  },
  "bin": {
    "lite-gc-gate": "./bin/LiteGcGate.mjs"
  },
  "files": [
    "Gc.js",
    "Gc.d.ts",
    "index.js",
    "index.d.ts",
    "Register.mjs",
    "TestHelpers.js",
    "TestHelpers.d.ts",
    "Explain.js",
    "Explain.d.ts",
    "bin/LiteGcGate.mjs",
    "templates/GcGate.mjs",
    "README.md",
    "CHANGELOG.md",
    "MIGRATE.md",
    "llms.txt",
    "LICENSE.txt"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "node --expose-gc --test 'test/*.test.mjs' 'test/torture/*.test.mjs'",
    "bundle-check": "npx esbuild Gc.js --bundle --format=esm --outfile=test-bundle.js",
    "prepublishOnly": "npm run test && npm run bundle-check"
  },
  "keywords": [
    "profiler",
    "gc",
    "garbage-collection",
    "heap",
    "memory",
    "zero-gc",
    "performance",
    "perf_hooks",
    "regression",
    "gate",
    "ci",
    "baseline",
    "differential",
    "lite"
  ],
  "author": "Zahary Shinikchiev <shinikchiev@yahoo.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/PeshoVurtoleta/lite-gc-profiler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/zakkster/lite-gc-profiler.git"
  },
  "bugs": {
    "url": "https://github.com/PeshoVurtoleta/lite-gc-profiler/issues",
    "email": "shinikchiev@yahoo.com"
  },
  "engines": {
    "node": ">=18"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/PeshoVurtoleta"
  }
}
